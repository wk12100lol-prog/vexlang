# sortowanie.vex - sortowanie bąbelkowe
funkcja sortuj(tab)
{
    licz n = dlugosc(tab)
    dla i w zakres(0, n - 1)
    {
        dla j w zakres(0, n - i - 2)
        {
            jeśli tab[j] > tab[j + 1] to
            {
                licz temp = tab[j]
                tab[j] = tab[j + 1]
                tab[j + 1] = temp
            }
        }
    }
    zwróć tab
}

tablica dane = [64, 34, 25, 12, 22, 11, 90]
pisz "Przed: " + dane
pisz "Po: " + sortuj(dane)
